# ─────────────────────────────────────────────────────────────────────────
# TrackBit Web — environment template
#
# Copy this file to `.env.local` and adjust if needed:
#     cp .env.example .env.local            # macOS / Linux
#     Copy-Item .env.example .env.local     # Windows PowerShell
#
# `.env.local` is gitignored — never commit it. Only this template is committed.
# ─────────────────────────────────────────────────────────────────────────

# Base URL of the TrackBit API (the backend). Must end with /api/v1.
# The default points at the backend running locally on port 8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
